# Ghostty configuration file.
#
# Run `ghostty +show-config --default --docs | nvim` to view a list of
# all available config options and their default values.
#
# Additionally, each config option is also explained in detail
# on Ghostty's website, at https://ghostty.org/docs/config.
#
# Ghostty can reload the configuration while running by using the menu
# options or the bound key (default: Command + Shift + comma on macOS and
# Control + Shift + comma on other platforms). Not all config options can be
# reloaded while running; some only apply to new windows and others may require
# a full restart to take effect.
#
# Examples: https://github.com/search?q=path%3Aghostty%2Fconfig&type=code


# Theme, run `ghostty +list-themes`
theme = Catppuccin Mocha

# Font, run `ghostty +list-fonts`
font-family = JetBrainsMono Nerd Font Mono
font-size = 14

# Terminal Background
background-opacity = 0.80
background-blur-radius = 40

# Mouse
mouse-hide-while-typing

# Keybindings, run `ghostty +list-keybinds --default` to see default Keybindings
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down

keybind = super+arrow_down=goto_split:down
keybind = super+arrow_left=goto_split:left
keybind = super+arrow_right=goto_split:right
keybind = super+arrow_up=goto_split:up

keybind = super+shift+arrow_up=resize_split:up,10
keybind = super+shift+arrow_down=resize_split:down,10
keybind = super+shift+arrow_left=resize_split:left,10
keybind = super+shift+arrow_right=resize_split:right,10

# Prior remap overwrites the default config for the following
# thu we remap them as well.
keybind = ctrl+shift+end=scroll_to_bottom
keybind = ctrl+shift+home=scroll_to_top
keybind = ctrl+shift+page_down=scroll_page_down
keybind = ctrl+shift+page_up=scroll_page_up
keybind = ctrl+shift+arrow_down=jump_to_prompt:1
keybind = ctrl+shift+arrow_left=text:\\x01
keybind = ctrl+shift+arrow_right=text:\\x05
keybind = ctrl+shift+arrow_up=jump_to_prompt:-1

